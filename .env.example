APP_NAME=Agent Competence API
APP_ENV=local
APP_DEBUG=true
ENABLE_FRANCE_TRAVAIL=true
ENABLE_JOOBLE=false
PUBLIC_REQUEST_TIMEOUT_SECONDS=20
PUBLIC_REQUEST_DELAY_SECONDS=2
PUBLIC_MAX_RESULTS=20
FRANCE_TRAVAIL_SEARCH_RADIUS_KM=10
DATABASE_URL=postgresql://agent_competence:agent_competence@localhost:5432/agent_competence
LOCAL_LLM_BASE_URL=http://localhost:1234
LOCAL_LLM_MODEL=qwen2.5-3b-instruct
LOCAL_LLM_TIMEOUT_SECONDS=45
